DATABASE_URL=sqlite:///./cv_analyzer.db

# Frontend URLs allowed by CORS
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]

# System email / SMTP configuration
# Example for Gmail: use an App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-system-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-system-email@gmail.com
SMTP_USE_TLS=true
